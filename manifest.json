{
  "name": "Ice",
  "description": "Ice is melting.",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "assets/icons/ice-16x16.png",
    "32": "assets/icons/ice-32x32.png",
    "48": "assets/icons/ice-48x48.png",
    "128": "assets/icons/ice-128x128.png"
  },
  "action": {
    "default_popup": "html/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "permissions": [
    "storage",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "*://cdc.vit.ac.in/*",
    "*://*.examly.io/*"
  ],
  "content_scripts": [
    {
      "js": [
        "content_scripts/key_handler.js",
        "content_scripts/modules/mcq/result_page.js",
        "content_scripts/modules/test_handler.js",
        "content_scripts/modules/url_handler.js",
        "content_scripts/modules/paste_handler.js",
        "content_scripts/login_handler.js",
        "content_scripts/modules/mcq/test_page.js"
      ],
      "matches": [
        "*://cdc.vit.ac.in/*",
        "*://vitplacement905.examly.io/*",
        "file:///C:/Users/tarun/Desktop/meta/*"
      ]
    }
  ]
}